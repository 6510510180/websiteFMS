PORT=3000

# Database (MySQL / MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=fms_db

# Cloudinary (ขอได้จาก console.cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS — ใส่ domain จริงที่จะเรียก API คั่นด้วย comma
# ตัวอย่าง: https://fms.psu.ac.th หรือหลาย domain
CORS_ORIGINS=https://your-domain.ac.th

# API Key (ตั้งค่าสุ่มที่ปลอดภัย)
API_KEY=change-me-to-random-secret
